{
  "name": "onion-flow",
  "private": true,
  "version": "0.1.0",
  "description": "Visual Novel Writing IDE with Node-based Story Design",
  "author": {
    "name": "mirokim",
    "email": "miro85a@gmail.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "generate-icons": "node -e \"const f=require('fs');if(f.existsSync('build/icon.png')){console.log('build/icon.png exists, skipping generation.');process.exit(0);}const s=require('sharp');f.mkdirSync('build',{recursive:true});s(f.readFileSync('public/onion.svg')).resize(512,512).png().toFile('build/icon.png')\"",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:build": "npm run generate-icons && npx vite build && npx electron-builder --config electron-builder.config.cjs",
    "electron:build:win": "npm run generate-icons && npx vite build && npx electron-builder --config electron-builder.config.cjs --win",
    "electron:build:mac": "npm run generate-icons && npx vite build && npx electron-builder --config electron-builder.config.cjs --mac",
    "electron:build:linux": "npm run generate-icons && npx vite build && npx electron-builder --config electron-builder.config.cjs --linux"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@tiptap/extension-character-count": "^3.19.0",
    "@tiptap/extension-color": "^3.19.0",
    "@tiptap/extension-dropcursor": "^3.19.0",
    "@tiptap/extension-gapcursor": "^3.19.0",
    "@tiptap/extension-heading": "^3.19.0",
    "@tiptap/extension-highlight": "^3.19.0",
    "@tiptap/extension-horizontal-rule": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-text-style": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@xyflow/react": "^12.10.0",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "i18next": "^25.8.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "recharts": "^3.7.0",
    "sql.js": "^1.14.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "cross-env": "^10.1.0",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
